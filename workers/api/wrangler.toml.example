name = "tugas-worker"
main = "src/index.ts"
compatibility_date = "2024-12-01"

[[d1_databases]]
binding = "DB"
database_name = "tugas-db"
database_id = "YOUR_D1_DATABASE_ID"

[[r2_buckets]]
binding = "TASK_FILES"
bucket_name = "task-files"

[[r2_buckets]]
binding = "SUBMISSION_FILES"
bucket_name = "submission-files"

[vars]
TASK_FILES_PUBLIC_URL = "https://pub-xxx.r2.dev"
SUBMISSION_FILES_PUBLIC_URL = "https://pub-yyy.r2.dev"

# Secrets (wrangler secret put):
# JWT_SECRET
# SETUP_KEY
